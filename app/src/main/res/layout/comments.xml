<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1F22"
    >


    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="#5865F2"
        />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:gravity="center_vertical"
        android:background="#2B2D31"
        >


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#949BA4"
            android:layout_marginEnd="6dp"
            />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="COMMENTS"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#F2F3F5"
            android:letterSpacing="0.15"
            />
        <ImageButton
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/outline_close_24"
            android:background="@android:color/transparent"
            android:padding="6dp"
            app:tint="#B5BAC1"
            />
    </LinearLayout>


    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#111214"
        />


    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"
        android:fadeScrollbars="true"
        android:clipToPadding="false"
        android:paddingVertical="8dp"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#2B2D31"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"
        >


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:paddingHorizontal="8dp"
            android:visibility="visible"
            >

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                />

            <ImageButton
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/outline_close_24"
                android:background="@android:color/transparent"
                app:tint="#949BA4"
                />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            >


            <ImageView
                android:id="@+id/imgCurrentUser"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:scaleType="centerCrop"
                android:background="@drawable/profpic_rounded"
                android:clipToOutline="true"
                android:layout_marginEnd="12dp"
                />


            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/postinput_border"
                android:backgroundTint="#383A40"
                android:paddingHorizontal="6dp"
                android:elevation="2dp"
                >

                <EditText
                    android:id="@+id/etCommentInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Type a transmission..."
                    android:textColor="#F2F3F5"
                    android:textColorHint="#949BA4"
                    android:background="@android:color/transparent"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="10dp"
                    android:maxLines="4"
                    android:textSize="14sp"
                    android:inputType="textMultiLine"
                    />


                <ImageButton
                    android:id="@+id/btnSendComment"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/outline_chat_bubble_24"
                    android:background="@android:color/transparent"
                    app:tint="#5865F2"
                    android:padding="8dp"
                    />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>